{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ScenarioGeneration",
  "type": "object",
  "required": ["triggerTime", "category", "title", "description", "severity", "sourceType", "options"],
  "properties": {
    "triggerTime": { "type": "string", "pattern": "^[0-2][0-9]:[0-5][0-9]$" },
    "category": {
      "type": "string",
      "enum": ["schedule", "staffing", "equipment", "content", "presenter", "vehicle", "robot", "safety", "client", "audience", "media", "weather", "venue", "comms", "power", "chain"]
    },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "relatedProgramId": { "type": ["string", "null"] },
    "relatedResourceId": { "type": ["string", "null"] },
    "sourceType": {
      "type": "string",
      "enum": ["deterministic_data", "probabilistic", "historical_case", "chain_reaction"]
    },
    "sourceReference": { "type": ["string", "null"] },
    "options": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["label", "description", "immediateEffects"],
        "properties": {
          "label": { "type": "string" },
          "description": { "type": "string" },
          "immediateEffects": {
            "type": "object",
            "required": ["schedule", "safety", "production", "client", "cost", "fatigue"],
            "properties": {
              "schedule": { "type": "number" },
              "safety": { "type": "number" },
              "production": { "type": "number" },
              "client": { "type": "number" },
              "cost": { "type": "number" },
              "fatigue": { "type": "number" }
            }
          },
          "newRiskTriggers": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
